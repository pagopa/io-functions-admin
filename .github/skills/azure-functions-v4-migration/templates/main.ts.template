// ---------------------------------------------------------------------------
// DURABLE FUNCTIONS — ACTIVITIES
//
// For each activity, register via df.app.activity().
// The handler receives (input, context) — note the swapped param order vs v3.
//
// Example:
// df.app.activity(ActivityName, {
//   handler: getActivityHandler(myModel),
// });
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// DURABLE FUNCTIONS — ORCHESTRATORS
//
// For each orchestrator, register via df.app.orchestration().
// Pass the generator function directly — no df.orchestrator() wrapper.
//
// Example:
// df.app.orchestration(
//   "MyOrchestrator",
//   getOrchestratorHandler({ dep1, dep2 }),
// );
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// QUEUE TRIGGERS
//
// For each queue trigger, register via app.storageQueue().
// The handler receives (queueItem, context).
